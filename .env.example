# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atlas:changeme@localhost:5432/atlas
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (MinIO locally, Cloudflare R2 in prod) ─────────────────────
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_BUCKET=atlas-documents
OBJECT_STORE_ACCESS_KEY=atlas
OBJECT_STORE_SECRET_KEY=changeme

# ── LLM APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # REQUIRED
OPENAI_API_KEY=sk-...                 # Optional: embedding fallback
COHERE_API_KEY=...                    # Optional: Cohere reranker

# ── Observability ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=atlas-development

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<minimum-32-random-bytes-replace-me>
JWT_ISSUER=atlas

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# ── MinIO (local only) ────────────────────────────────────────────────────────
MINIO_PASSWORD=atlas-minio-pw
